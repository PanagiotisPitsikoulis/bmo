{
	"name": "bmo",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3"
	},
	"scripts": {
		"start": "bun --bun run index.ts",
		"dev": "bun --bun --hot src/web/server.ts",
		"build": "bun run src/web/build.ts",
		"build:pi": "bun build --compile --minify --sourcemap --bytecode --target=bun-linux-arm64 ./src/index.ts --outfile dist/bmo",
		"test": "bun test",
		"kill": "pkill -f 'bun.*server\\.ts' || true; lsof -ti :3000 | xargs kill -9 2>/dev/null || echo 'No bun servers running'"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"@phosphor-icons/react": "^2.1.10",
		"@tailwindcss/typography": "^0.5.19",
		"bun-plugin-tailwind": "^0.1.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"marked": "^17.0.3",
		"motion": "^12.34.5",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0"
	}
}
